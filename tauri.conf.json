{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VORTEX Shell",
  "version": "0.1.0",
  "identifier": "com.vortex.shell",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VORTEX Shell",
        "label": "main",
        "width": 1920,
        "height": 112,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false,
        "x": 0,
        "y": 0
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
